generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  ADMIN
  SALES
  OPS
  VIEWER
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum AssetType {
  IMAGE
  MODEL_3D
  DATASHEET
  PDF
}

enum InquiryStatus {
  NEW
  REVIEWING
  QUOTED
  CLOSED
  LOST
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum CustomerSegment {
  DISTRIBUTOR
  OEM
  CONTRACTOR
  MAINTENANCE
  SUPPLIER
  END_USER
}

enum CostBucketType {
  LABOR
  ELECTRICITY
  MAINTENANCE
  EQUIPMENT
  WAREHOUSE_RENT
  RAW_MATERIALS
  LOGISTICS
  OTHER
}

enum MarketCode {
  GLOBAL
  UAE
  SAUDI_ARABIA
  OMAN
  QATAR
}

enum CurrencyCode {
  AED
  SAR
  OMR
  QAR
  USD
}

enum CompetitorSourceType {
  MANUAL
  CSV_IMPORT
  WEB_RESEARCH
}

enum ImportSourceType {
  CSV
  IMAGE
  MANUAL
}

enum ImportBatchStatus {
  PENDING
  PROCESSED
  PARTIAL
  FAILED
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String?
  role          UserRole     @default(OWNER)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  assignedRfqs  Rfq[]        @relation("RfqAssignee")
  createdQuotes Quote[]      @relation("QuoteCreator")
  importBatches ImportBatch[]
}

model Customer {
  id            String           @id @default(cuid())
  companyName   String
  contactName   String?
  email         String?
  phone         String?
  segment       CustomerSegment?
  market        MarketCode
  city          String?
  addressLine1  String?
  notes         String?
  sourceChannel String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  rfqs          Rfq[]
  quotes        Quote[]
}

model Product {
  id                       String              @id @default(cuid())
  slug                     String              @unique
  name                     String
  category                 String
  material                 String
  summary                  String
  description              String
  features                 String[]
  certifications           String[]
  applications             String[]
  industries               String[]
  supplyFormats            String[]
  qualityChecks            String[]
  sourcingNotes            String[]
  technicalProfile         Json?
  ownerPriceBookNotes      String?
  status                   ProductStatus       @default(DRAFT)
  isFeatured               Boolean             @default(false)
  ownerOnlyManufacturing   Boolean             @default(true)
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  variants                 ProductVariant[]
  assets                   ProductAsset[]
  manufacturingRecord      ManufacturingRecord?
  competitorProducts       CompetitorProduct[]
}

model ProductVariant {
  id                   String             @id @default(cuid())
  productId            String
  code                 String             @unique
  description          String
  minimumOrderQuantity Int
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  product              Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  dimensions           VariantDimension[]
  prices               ProductPrice[]
  rfqItems             RfqItem[]
  quoteLines           QuoteLine[]
}

model VariantDimension {
  id        String         @id @default(cuid())
  variantId String
  label     String
  value     String
  sortOrder Int            @default(0)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId, sortOrder])
}

model ProductAsset {
  id         String    @id @default(cuid())
  productId  String
  type       AssetType
  title      String
  storageKey String
  mimeType   String?
  isPublic   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductPrice {
  id            String       @id @default(cuid())
  variantId     String
  market        MarketCode
  currency      CurrencyCode
  amount        Decimal      @db.Decimal(12, 3)
  isPublic      Boolean      @default(false)
  effectiveFrom DateTime     @default(now())
  effectiveTo   DateTime?
  variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId, market, currency, effectiveFrom])
}

model Rfq {
  id              String        @id @default(cuid())
  customerId      String
  requestedMarket MarketCode
  status          InquiryStatus @default(NEW)
  sourceChannel   String?
  notes           String?
  assignedToId    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  customer        Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  assignedTo      User?         @relation("RfqAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  items           RfqItem[]
  quote           Quote?
}

model RfqItem {
  id                  String          @id @default(cuid())
  rfqId               String
  variantId           String?
  requestedProductName String?
  quantity            Int
  applicationNotes    String?
  attachmentReference String?
  rfq                 Rfq             @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  variant             ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
}

model Quote {
  id          String       @id @default(cuid())
  rfqId       String?      @unique
  customerId  String
  createdById String?
  status      QuoteStatus  @default(DRAFT)
  currency    CurrencyCode
  validUntil  DateTime?
  subtotal    Decimal      @default(0) @db.Decimal(12, 3)
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  rfq         Rfq?         @relation(fields: [rfqId], references: [id], onDelete: SetNull)
  customer    Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy   User?        @relation("QuoteCreator", fields: [createdById], references: [id], onDelete: SetNull)
  lines       QuoteLine[]
}

model QuoteLine {
  id        String         @id @default(cuid())
  quoteId   String
  variantId String
  quantity  Int
  unitPrice Decimal        @db.Decimal(12, 3)
  lineTotal Decimal        @db.Decimal(12, 3)
  quote     Quote          @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
}

model InternalCostEntry {
  id              String         @id @default(cuid())
  bucket          CostBucketType
  title           String
  amountUsd       Decimal        @db.Decimal(12, 3)
  allocationBasis String?
  notes           String?
  periodStart     DateTime
  periodEnd       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model ManufacturingRecord {
  id          String                  @id @default(cuid())
  productId   String                  @unique
  compoundCode String?
  processNotes String
  cureSystem   String?
  curingNotes  String?
  qaNotes      String?
  qaChecks     String[]
  batchSizeKg  Int?
  monthlyOutputKg Int?
  scrapRate    String?
  ownerOnly    Boolean                @default(true)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  product      Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredients  ManufacturingIngredient[]
}

model ManufacturingIngredient {
  id                    String              @id @default(cuid())
  manufacturingRecordId String
  materialName          String
  percentage            Decimal             @db.Decimal(6, 3)
  supplierName          String?
  origin                String?
  sourceType            String?
  landedCostUsdPerKg    Decimal?            @db.Decimal(12, 3)
  leadTimeDays          Int?
  supplierNotes         String?
  manufacturingRecord   ManufacturingRecord @relation(fields: [manufacturingRecordId], references: [id], onDelete: Cascade)
}

model CompetitorProduct {
  id                    String               @id @default(cuid())
  productId             String?
  competitorName        String
  competitorProductName String
  sourceType            CompetitorSourceType
  sourceReference       String
  capturedAt            DateTime
  confidenceScore       Int
  notes                 String?
  createdAt             DateTime             @default(now())
  product               Product?             @relation(fields: [productId], references: [id], onDelete: SetNull)
  prices                CompetitorPrice[]
}

model CompetitorPrice {
  id                  String            @id @default(cuid())
  competitorProductId String
  market              MarketCode
  currency            CurrencyCode
  amount              Decimal           @db.Decimal(12, 3)
  minimumOrderQuantity Int?
  competitorProduct   CompetitorProduct @relation(fields: [competitorProductId], references: [id], onDelete: Cascade)
}

model ImportBatch {
  id           String            @id @default(cuid())
  fileName     String
  sourceType   ImportSourceType
  status       ImportBatchStatus @default(PENDING)
  rowCount     Int               @default(0)
  successfulRowCount Int         @default(0)
  failedRowCount Int             @default(0)
  notes        String?
  importedById String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  importedBy   User?             @relation(fields: [importedById], references: [id], onDelete: SetNull)
}